{
  "expo": {
    "name": "CineBluish",
    "slug": "CineBluish",
    "scheme": "cinebluish",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#050816"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#050816"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.neelesh7.CineBluish"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "6d0ff73d-44b2-4228-a749-1c6e69ee6553"
      }
    }
  }
}
